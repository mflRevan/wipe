{
  "name": "wipe",
  "version": "0.1.0",
  "description": "Thin npm install wrapper for wipe, a CLI-first, git-native collaboration tool for humans and agents. Downloads the prebuilt `wipe` binary from GitHub Releases on install.",
  "bin": {
    "wipe": "bin/wipe.js"
  },
  "scripts": {
    "postinstall": "node ./install.js"
  },
  "files": [
    "install.js",
    "bin/"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mflRevan/wipe.git",
    "directory": "npm"
  },
  "homepage": "https://github.com/mflRevan/wipe",
  "bugs": {
    "url": "https://github.com/mflRevan/wipe/issues"
  },
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "cli",
    "kanban",
    "agents",
    "git",
    "collaboration",
    "wipe"
  ],
  "author": "Bilal <bilal@bigitec.com>"
}
