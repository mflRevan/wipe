# Normalize line endings to LF across platforms so diffs stay clean.
* text=auto eol=lf

*.rs    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ts    text eol=lf
*.svelte text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Generated / lock files
Cargo.lock text eol=lf linguist-generated=true

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
